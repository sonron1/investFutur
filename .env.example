# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Connection pooling URL (used by Prisma at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/investfutur?sslmode=require&pgbouncer=true&connect_timeout=15"
# Direct connection URL (used by Prisma Migrate)
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/investfutur?sslmode=require"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="InvestFutur <noreply@investfutur.fr>"

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
APP_NAME="InvestFutur"
NODE_ENV="development"
