# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Pooler URL — utilisée par l'app en runtime (Vercel + dev)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Direct URL — utilisée par prisma db push/migrate uniquement
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── Authentication ───────────────────────────────────────────────────────────
# Générez avec: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET="your-super-secret-jwt-key-min-64-chars"
JWT_REFRESH_SECRET="your-different-refresh-secret-min-64-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
# Sans domaine custom : utiliser onboarding@resend.dev (test/dev)
# Avec domaine custom vérifié : InvestFutur <noreply@votredomaine.fr>
EMAIL_FROM="InvestFutur <onboarding@resend.dev>"

# ─── Seed (dev only) ─────────────────────────────────────────────────────────
SEED_ADMIN_PASSWORD="choose-a-strong-admin-password"
SEED_DEMO_PASSWORD="choose-a-strong-demo-password"

# ─── App ─────────────────────────────────────────────────────────────────────
# En développement local
APP_URL="http://localhost:3000"
# En production Vercel (sans domaine custom)
# APP_URL="https://invest-futur.vercel.app"
APP_NAME="InvestFutur"
NODE_ENV="development"
